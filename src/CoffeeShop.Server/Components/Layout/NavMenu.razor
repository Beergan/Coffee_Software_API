@using MudBlazor

<MudNavMenu>
    <MudText Typo="Typo.h6" Class="px-4 pt-4 pb-2">Coffee Shop</MudText>
    <MudDivider />
    
    <AuthorizeView>
        <Authorized>
            <!-- Staff Menu Items -->
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="Icons.Material.Filled.Dashboard">
                Dashboard
            </MudNavLink>
            
            <MudNavLink Href="/orders" Icon="Icons.Material.Filled.ShoppingCart">
                Orders
            </MudNavLink>
            
            <MudNavLink Href="/products" Icon="Icons.Material.Filled.LocalCafe">
                Products
            </MudNavLink>
            
            <!-- Manager/Admin Menu Items -->
            <AuthorizeView Roles="Manager,Admin" Context="managerContext">
                <Authorized>
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.body2" Class="px-4 mud-text-secondary">Management</MudText>
                    
                    <MudNavLink Href="/staff" Icon="Icons.Material.Filled.People">
                        Staff Management
                    </MudNavLink>
                    
                    <MudNavLink Href="/reports" Icon="Icons.Material.Filled.Assessment">
                        Reports
                    </MudNavLink>
                    
                    <MudNavLink Href="/inventory" Icon="Icons.Material.Filled.Inventory">
                        Inventory
                    </MudNavLink>
                </Authorized>
            </AuthorizeView>
            
            <!-- Admin Only Menu Items -->
            <AuthorizeView Roles="Admin" Context="adminContext">
                <Authorized>
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.body2" Class="px-4 mud-text-secondary">Admin</MudText>
                    
                    <MudNavLink Href="/settings" Icon="Icons.Material.Filled.Settings">
                        Settings
                    </MudNavLink>
                </Authorized>
            </AuthorizeView>
        </Authorized>
        <NotAuthorized>
            <MudNavLink Href="/Account/Login" Icon="Icons.Material.Filled.Login">
                Login
            </MudNavLink>
        </NotAuthorized>
    </AuthorizeView>
</MudNavMenu>

